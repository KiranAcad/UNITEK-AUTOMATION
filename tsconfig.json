{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "dom"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["pages/*"],
      "@locators/*": ["locators/*"],
      "@utils/*": ["utils/*"],
      "@helpers/*": ["helpers/*"],
      "@fixtures/*": ["fixtures/*"],
      "@config/*": ["config/*"],
      "@constants/*": ["constants/*"],
      "@test-data/*": ["test-data/*"]
    }
  },
  "include": [
    "tests/**/*.ts",
    "pages/**/*.ts",
    "locators/**/*.ts",
    "utils/**/*.ts",
    "helpers/**/*.ts",
    "fixtures/**/*.ts",
    "config/**/*.ts",
    "constants/**/*.ts",
    "test-data/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "reports"]
}
