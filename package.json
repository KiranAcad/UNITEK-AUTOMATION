{
  "name": "unitek-automation",
  "version": "1.0.0",
  "description": "Enterprise-level Playwright + TypeScript UI Automation Framework for Unitek College",
  "author": "QA Team",
  "license": "ISC",
  "scripts": {
    "pretest": "rimraf test-results reports/custom-report.html",
    "pretest:qa": "npm run pretest",
    "pretest:uat": "npm run pretest",
    "pretest:staging": "npm run pretest",
    "pretest:prod": "npm run pretest",
    "test": "npx playwright test",
    "test:qa": "cross-env TEST_ENV=qa npx playwright test",
    "test:smoke": "cross-env TEST_ENV=qa npx playwright test --grep \"@smoke|@sanity\" --project=chromium",
    "test:uat": "cross-env TEST_ENV=uat npx playwright test",
    "test:staging": "cross-env TEST_ENV=staging npx playwright test",
    "test:prod": "cross-env TEST_ENV=prod npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:chromium": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:webkit": "npx playwright test --project=webkit",
    "test:debug": "npx playwright test --debug",
    "test:ui": "npx playwright test --ui",
    "test:failed": "node utils/run-failed.js",
    "report": "start reports/custom-report.html",
    "lint": "eslint . --ext .ts",
    "clean": "rimraf reports screenshots videos logs test-results"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@faker-js/faker": "^9.3.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^25.9.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0"
  }
}
